{
  "name": "milsymbol-delta",
  "version": "3.0.4",
  "description": "Milsymbol.js fork with optional Delta icon patch for MIL-STD-2525 and APP6 symbols.",
  "type": "module",
  "exports": {
    ".": {
      "require": "./dist/milsymbol.js",
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./delta": {
      "import": "./delta/index.js",
      "require": "./dist/milsymbol-delta.cjs",
      "types": "./delta/index.d.ts"
    },
    "./delta/missing-only": {
      "import": "./delta/missing-only.js",
      "require": "./dist/milsymbol-delta-missing-only.cjs",
      "types": "./delta/missing-only.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/milsymbol.js",
  "module": "./index.js",
  "browser": "./dist/milsymbol.js",
  "types": "./index.d.ts",
  "files": [
    "./dist",
    "./src",
    "./delta",
    "./index.js",
    "./index.mjs",
    "./index.d.ts"
  ],
  "scripts": {
    "lint": "eslint src test --fix",
    "prebuild": "npm run lint && npm test",
    "build": "npm run bundle && npm run bundle:delta && npm run minify",
    "postbuild": "node --eval \"const fs = require('node:fs'); fs.writeFileSync('./dist/package.json', JSON.stringify({ type: 'commonjs' }));\"",
    "bundle": "rollup -c",
    "bundle:delta": "rollup -c rollup.delta.config.mjs",
    "generate:missing-sidc": "node dev/generate-delta-missing-sidc-set.mjs",
    "minify": "npm run minify:base && npm run minify:delta",
    "minify:base": "uglifyjs dist/milsymbol.development.js -o dist/milsymbol.js --comments --compress --mangle --source-map",
    "minify:delta": "uglifyjs dist/milsymbol-delta-patch.js -o dist/milsymbol-delta-patch.min.js --comments --compress --mangle && uglifyjs dist/milsymbol-delta-missing-only-patch.js -o dist/milsymbol-delta-missing-only-patch.min.js --comments --compress --mangle",
    "test": "tead --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexkolodko/milsymbol-delta.git"
  },
  "author": "Måns Beckman (http://www.spatialillusions.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/spatialillusions/milsymbol/issues"
  },
  "homepage": "https://github.com/alexkolodko/milsymbol-delta",
  "devDependencies": {
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mil-std-2525": "^0.2.8",
    "milstandard-e": "^0.2.14",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "rollup-plugin-copy": "^3.5.0",
    "stanag-app6": "^0.2.0",
    "tead": "^0.7.1",
    "uglify-js": "^3.19.3"
  },
  "babel": {
    "presets": "env"
  }
}
